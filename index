      }
    },
    brakes: {
      role: "Ты — специалист по тормозным системам, включая ABS, ESP, гидроблоки.",
      task: "Диагностируй неисправность тормозов. Опиши проверку колодок, дисков, тормозной жидкости, датчиков ABS.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Безопасность прежде всего: проверь уровень жидкости, целостность трубок.\n2. Считай ошибки блока ABS.\n3. Предложи тест на срабатывание ABS при наличии.",
      hints: {
        template: "🛑 Тормоза. Опасно! Проверяй скрип, вибрацию педали, увеличенный путь, загоревшуюся лампу ABS.",
        brand: "Примеры: Honda, Skoda, ГАЗель. Учитывай особенности системы (барабанные/дисковые).",
        model: "Уточни модификацию: «Octavia A7», «Civic 10».",
        symptoms: ["скрип при торможении", "вибрация педали", "увеличенный тормозной путь", "горит ABS", "педаль проваливается", "машину тянет при торможении"]
      }
    },
    electrical: {
      role: "Ты — автоэлектрик-диагност, разбираешься в CAN-шинах, генераторах, стартерах, блоках управления.",
      task: "Найди причину электрической неисправности. Предложи алгоритм проверки напряжения, предохранителей, массы, блоков управления.",
