      rules: "1. Начни с АКБ и предохранителей.\n2. Проверь просадки напряжения мультиметром.\n3. При сложных случаях используй осциллограф или дилерский сканер.",
      hints: {
        template: "⚡ Электрика. Всё, что мигает/не горит/не крутит. Проверь клеммы, массу, генератор. Может потребоваться схема.",
        brand: "Укажи марку: у некоторых проблемы с проводкой (например, Peugeot, Land Rover).",
        model: "Напиши, например, «308 T9», «Freelander 2».",
        symptoms: ["не заводится", "стартер не крутит", "тусклый свет фар", "ошибка по CAN-шине", "садится аккумулятор", "не работают стеклоподъёмники", "горит гирлянда на панели"]
      }
    },
    body: {
      role: "Ты — эксперт по кузовному ремонту и оценке состояния ЛКП, геометрии кузова.",
      task: "Оцени состояние кузова/ЛКП по описанным симптомам. Укажи возможные причины коррозии, дефектов покраски, зазоров.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Проверь толщину ЛКП толщиномером.\n2. Осмотри сварные швы.\n3. Исключи скрытые повреждения после ДТП.",
      hints: {
        template: "🎨 Кузов/ЛКП. Ржавчина, сколы, шагрень, несовпадение оттенка. Понадобится толщиномер.",
        brand: "Любая. Некоторые бренды склонны к коррозии (Mazda, старые Opel).",
        model: "Например, «Mazda 3 BK», «Astra H».",
        symptoms: ["ржавчина на арках", "сколы до металла", "вздутие краски", "неравномерные зазоры", "следы шпаклёвки", "разнотон дверей"]
      }
    },
    climate: {
      role: "Ты — специалист по системам кондиционирования и отопления автомобиля.",
      task: "Диагностируй неисправность климат-контроля. Предложи проверку фреона, компрессора, датчиков, заслонок.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Проверь давление в системе кондиционера.\n2. Считай ошибки блока климата.\n3. Осмотри радиатор кондиционера на герметичность.",
      hints: {
        template: "❄️ Климат. Нет холода/тепла, запах, шум вентилятора. Нужен манометр и термометр.",
        brand: "Пример: Toyota, Ford, BMW — у них разные типы компрессоров.",
        model: "Уточни: «Corolla E210», «Focus Mk4».",
        symptoms: ["не холодит", "тепло не дует", "кондиционер включается с шумом", "неприятный запах", "запотевают стёкла", "ошибка климат-контроля"]
      }
    },
    fuel: {
      role: "Ты — диагност топливных систем (бензин/дизель). Знаешь всё о насосах, форсунках, фильтрах, давлении.",
      task: "Определи причину проблемы с подачей топлива. Предложи замер давления, проверку форсунок, тест насоса.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Проверь давление в рампе (эталонное значение).\n2. Сними показания коррекции топливоподачи.\n3. Проверь форсунки на стенде/баланс тест.",
      hints: {
        template: "⛽ Топливная. Перебои, расход, запах бензина. Нужен манометр топливной рампы.",
        brand: "Дизель/бензин: Bosch, Delphi, Denso — система впрыска зависит от марки.",
        model: "Пример: «Megane 1.5 dCi», «Solaris 1.6 MPI».",
        symptoms: ["троит", "не заводится на горячую", "повышенный расход", "пахнет бензином", "потеря тяги", "чёрный дым", "захлёбывается"]
      }
    },
    exhaust: {
      role: "Ты — специалист по выхлопным системам и нейтрализации (катализаторы, сажевые фильтры, лямбда-зонды).",
      task: "Диагностируй проблемы с выхлопом. Проверь состояние катализатора, датчиков кислорода, герметичность системы.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Считай ошибки по лямбда-зондам и пропускам зажигания.\n2. Проверь противодавление выхлопа.\n3. Осмотри визуально на прогары.",
      hints: {
        template: "💨 Выхлоп. Дым, запах, ошибки P0420/P0430. Проверь катализатор, лямбды.",
        brand: "Пример: VW (проблемные сажевые фильтры), Subaru (катализаторы).",
        model: "Укажи: «Tiguan 2.0 TDI», «Forester 2.5».",
        symptoms: ["горит Check Engine (P0420)", "чёрный/сизый дым", "запах сероводорода", "потеря мощности", "дребезг", "ошибка сажевого фильтра"]
      }
    },
    general: {
      role: "Ты — универсальный автоэксперт-диагност, способный комплексно оценить состояние автомобиля.",
      task: "Проведи общее диагностирование по всем системам. Выдели критические, средние и незначительные замечания.",
      context: "Автомобиль: [Марка] [Модель]. Симптомы: [Симптомы].",
      rules: "1. Проверь историю обслуживания.\n2. Проведи визуальный осмотр.\n3. Подключи сканер OBD2 и считай все ошибки.\n4. Дай рекомендации по приоритетам ремонта.",
      hints: {
        template: "📋 Полная диагностика. Всё сразу. Опиши всё необычное: от стуков до лампочек.",
        brand: "Любая марка.",
        model: "Например, «Ceed 2018», «A6 C7».",
        symptoms: ["Check Engine", "стук", "люфт", "скрип", "ошибка ABS", "вибрация", "неисправность", "шум", "течь"]
      }
    }
  };

  // Функция открытия/закрытия панели подсказок
  function toggleHint(panelId, btnId) {
    const panel = document.getElementById(panelId);
    const btn = document.getElementById(btnId);
    if (panel.classList.contains('open')) {
      panel.classList.remove('open');
    } else {
      // Закрыть все остальные открытые панели
      document.querySelectorAll('.hint-panel.open').forEach(p => p.classList.remove('open'));
      panel.classList.add('open');
    }
  }

  // Заполнение подсказок при выборе шаблона
  function updateHints() {
    const templateKey = document.getElementById('templateSelect').value;
    const t = templates[templateKey];
    if (!t) return;

    // Общие подсказки шаблона
    document.getElementById('hintTemplate').innerHTML = t.hints.template;
    document.getElementById('hintBrand').innerHTML = t.hints.brand;
    document.getElementById('hintModel').innerHTML = t.hints.model;

    // Симптомы: список и чипсы
    const symptomsList = t.hints.symptoms.map(s => `<li>${s}</li>`).join('');
    document.getElementById('hintSymptoms').innerHTML = `<ul>${symptomsList}</ul>`;

    const chipContainer = document.getElementById('symptomChips');
    chipContainer.innerHTML = '';
    t.hints.symptoms.forEach(symptom => {
      const chip = document.createElement('span');
      chip.className = 'chip';
      chip.textContent = symptom;
      chip.addEventListener('click', () => {
        const textarea = document.getElementById('symptoms');
        if (textarea.value.trim() === '') {
          textarea.value = symptom;
        } else {
          textarea.value += ', ' + symptom;
        }
        // Закрываем панель симптомов после выбора (опционально)
        // document.getElementById('hintSymptoms').classList.remove('open');
      });
      chipContainer.appendChild(chip);
    });
  }

  // Обработчики для кнопок 💡
  document.getElementById('hintTemplateBtn').addEventListener('click', () => toggleHint('hintTemplate', 'hintTemplateBtn'));
  document.getElementById('hintBrandBtn').addEventListener('click', () => toggleHint('hintBrand', 'hintBrandBtn'));
  document.getElementById('hintModelBtn').addEventListener('click', () => toggleHint('hintModel', 'hintModelBtn'));
  document.getElementById('hintSymptomsBtn').addEventListener('click', () => toggleHint('hintSymptoms', 'hintSymptomsBtn'));

  // Закрытие подсказок при клике вне
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.hint-btn') && !e.target.closest('.hint-panel')) {
      document.querySelectorAll('.hint-panel.open').forEach(p => p.classList.remove('open'));
    }
  });

  // Сборка промпта
  function assemblePrompt() {
    const templateKey = document.getElementById('templateSelect').value;
    const t = templates[templateKey];
    const brand = document.getElementById('brand').value.trim() || '[Марка]';
    const model = document.getElementById('model').value.trim() || '[Модель/Год/Двигатель]';
    const symptoms = document.getElementById('symptoms').value.trim() || '[Симптомы]';
    const chain = document.getElementById('chainOfThought').checked;
    const security = document.getElementById('security').checked;

    let context = t.context.replace('[Марка]', brand).replace('[Модель/Год/Двигатель]', model).replace('[Модель]', model).replace('[Симптомы]', symptoms);

    let prompt = `РОЛЬ: ${t.role}\n\n`;
    prompt += `ЗАДАЧА: ${t.task}\n\n`;
    prompt += `КОНТЕКСТ: ${context}\n\n`;
    prompt += `ПРАВИЛА: ${t.rules}\n\n`;

    if (chain) prompt += "ЦЕПОЧКА РАССУЖДЕНИЙ: Думай шаг за шагом, объясняй каждый этап.\n\n";
    if (security) prompt += "БЕЗОПАСНОСТЬ: Отметь все шаги, связанные с риском для жизни (высокое напряжение, топливная система, подушки безопасности). Если симптом критический — порекомендуй немедленно прекратить эксплуатацию.\n";

    return prompt;
  }

  document.getElementById('generateBtn').addEventListener('click', () => {
    const prompt = assemblePrompt();
    document.getElementById('promptResult').textContent = prompt;
    document.getElementById('outputBlock').style.display = 'block';
  });

  document.getElementById('copyBtn').addEventListener('click', () => {
    const text = document.getElementById('promptResult').textContent;
    navigator.clipboard.writeText(text).then(() => alert('Промпт скопирован!'));
  });

  document.getElementById('resetBtn').addEventListener('click', () => {
    document.getElementById('brand').value = '';
    document.getElementById('model').value = '';
    document.getElementById('symptoms').value = '';
    document.getElementById('outputBlock').style.display = 'none';
  });

  // Обновление подсказок при смене шаблона
  document.getElementById('templateSelect').addEventListener('change', updateHints);

  // Инициализация при загрузке
  updateHints();
</script>
</body>
</html>
